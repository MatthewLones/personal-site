---
---
<canvas id="hat-tiling-canvas" class="hat-tiling-bg"></canvas>
<span id="tile-click-counter" class="tile-click-counter" aria-hidden="true"></span>

<script>
  import { generateHatTiling, pointInPolygon, type HatTileResult } from '../../lib/hat-monotile';

  // Parse hex color to [r, g, b]
  function hexToRgb(hex: string): [number, number, number] {
    hex = hex.replace('#', '');
    return [
      parseInt(hex.substring(0, 2), 16),
      parseInt(hex.substring(2, 4), 16),
      parseInt(hex.substring(4, 6), 16),
    ];
  }

  // Lerp between two colors
  function lerpColor(a: [number, number, number], b: [number, number, number], t: number): [number, number, number] {
    return [
      Math.round(a[0] + (b[0] - a[0]) * t),
      Math.round(a[1] + (b[1] - a[1]) * t),
      Math.round(a[2] + (b[2] - a[2]) * t),
    ];
  }

  // Darken a color by a factor (0 = unchanged, 1 = black)
  function darkenColor(rgb: [number, number, number], amount: number): [number, number, number] {
    return [
      Math.round(rgb[0] * (1 - amount)),
      Math.round(rgb[1] * (1 - amount)),
      Math.round(rgb[2] * (1 - amount)),
    ];
  }

  class HatTilingRenderer {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private tiles: HatTileResult[] = [];
    private hoveredTile: number = -1;

    // Design tokens (read from CSS)
    private outlineColor = '#2a3020';
    private outlineOpacity = 0.35;
    private hoverDarken = 0.08;
    private hoverHold = 0.3;   // seconds to hold at full highlight
    private hoverFade = 0.7;   // seconds to fade from full to zero
    private tileSizeScale = 1.0;
    private clickDarken = 0.15;
    private clickScale = 1.25;
    private clickDuration = 0.15;  // seconds — snap-back time on release
    private bgLight: [number, number, number] = [188, 198, 175];
    private bgDark: [number, number, number] = [60, 69, 49];

    // Tiling transform
    private scale = 1;
    private offsetX = 0;
    private offsetY = 0;

    // Scroll state
    private scrollY = 0;

    // Content card edges (tiles render outside these bounds)
    private cardLeft = Infinity;
    private cardAbsBottom = Infinity; // absolute (document) Y of card bottom

    // Hover trail: tiles that were recently hovered, fading out
    private coolingTiles: Map<number, number> = new Map(); // tileIndex → timestamp
    // Click pop animation: tiles scaling up, holding, then snapping back
    private poppingTiles: Map<number, { pressTime: number; releaseTime: number }> = new Map();
    private heldTile: number = -1; // tile currently being held down
    private pendingRender = false;

    // Pointer interpolation: track last pointer position for line-sweep
    private lastPointerX = -1;
    private lastPointerY = -1;

    // Easter egg: click counter
    private clickCount = 0;
    private clickCounterEl: HTMLElement | null = null;

    // Ripple: expanding wavefront from each click
    private ripples: { cx: number; cy: number; time: number }[] = [];
    private rippleSpeed = 800;
    private rippleFade = 0.3;
    private rippleRadius = 600;

    // Footer tiling zone (organic curved boundary)
    private footerRise = 200;        // px higher at edges vs center
    private footerFade = 100;        // px fade distance

    // Audio: subtle pen-click via Web Audio API
    private audioCtx: AudioContext | null = null;

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;

      // Read CSS custom properties
      const styles = getComputedStyle(document.documentElement);
      const outlineHex = styles.getPropertyValue('--tile-outline-color').trim();
      if (outlineHex) this.outlineColor = outlineHex;
      const opacity = parseFloat(styles.getPropertyValue('--tile-outline-opacity').trim());
      if (!isNaN(opacity)) this.outlineOpacity = opacity;
      const darken = parseFloat(styles.getPropertyValue('--tile-hover-darken').trim());
      if (!isNaN(darken)) this.hoverDarken = darken;
      const hold = parseFloat(styles.getPropertyValue('--tile-hover-hold').trim());
      if (!isNaN(hold)) this.hoverHold = hold;
      const fade = parseFloat(styles.getPropertyValue('--tile-hover-fade').trim());
      if (!isNaN(fade)) this.hoverFade = fade;
      const sizeScale = parseFloat(styles.getPropertyValue('--tile-size-scale').trim());
      if (!isNaN(sizeScale)) this.tileSizeScale = sizeScale;
      const clickDarken = parseFloat(styles.getPropertyValue('--tile-click-darken').trim());
      if (!isNaN(clickDarken)) this.clickDarken = clickDarken;
      const clickScale = parseFloat(styles.getPropertyValue('--tile-click-scale').trim());
      if (!isNaN(clickScale)) this.clickScale = clickScale;
      const clickDuration = parseFloat(styles.getPropertyValue('--tile-click-duration').trim());
      if (!isNaN(clickDuration)) this.clickDuration = clickDuration;
      const rippleSpeed = parseFloat(styles.getPropertyValue('--tile-ripple-speed').trim());
      if (!isNaN(rippleSpeed)) this.rippleSpeed = rippleSpeed;
      const rippleFade = parseFloat(styles.getPropertyValue('--tile-ripple-fade').trim());
      if (!isNaN(rippleFade)) this.rippleFade = rippleFade;
      const rippleRadius = parseFloat(styles.getPropertyValue('--tile-ripple-radius').trim());
      if (!isNaN(rippleRadius)) this.rippleRadius = rippleRadius;

      const bgLightHex = styles.getPropertyValue('--color-bg-light').trim();
      const bgDarkHex = styles.getPropertyValue('--color-bg-dark').trim();
      if (bgLightHex) this.bgLight = hexToRgb(bgLightHex);
      if (bgDarkHex) this.bgDark = hexToRgb(bgDarkHex);

      const footerRise = parseFloat(styles.getPropertyValue('--tile-footer-rise').trim());
      if (!isNaN(footerRise)) this.footerRise = footerRise;
      const footerFade = parseFloat(styles.getPropertyValue('--tile-footer-fade').trim());
      if (!isNaN(footerFade)) this.footerFade = footerFade;

      this.clickCounterEl = document.getElementById('tile-click-counter');
      this.init();
    }

    private init() {
      // Generate tiling first, then set up canvas
      this.tiles = generateHatTiling(4);
      this.setupCanvas();
      this.computeTransform();
      this.updateCardBounds();
      this.scrollY = window.scrollY;

      window.addEventListener('resize', () => {
        this.setupCanvas();
        this.computeTransform();
        this.updateCardBounds();
        this.scheduleRender();
      });
      // Re-measure card bounds when content changes size (e.g. puzzle canvases init)
      const card = document.querySelector('.content-card');
      if (card) {
        new ResizeObserver(() => {
          this.updateCardBounds();
          this.scheduleRender();
        }).observe(card);
      }
      window.addEventListener('scroll', () => {
        this.scrollY = window.scrollY;
        this.scheduleRender();
      }, { passive: true });
      document.addEventListener('pointermove', (e) => this.onPointerMove(e));
      document.addEventListener('pointerdown', (e) => this.onPointerDown(e));
      document.addEventListener('pointerup', () => this.onPointerUp());
      document.addEventListener('pointerleave', () => this.onPointerLeave());

      this.scheduleRender();
      window.dispatchEvent(new CustomEvent('component-ready', { detail: { id: 'hat-tiling' } }));
    }

    private setupCanvas() {
      const dpr = window.devicePixelRatio || 1;
      const w = window.innerWidth;
      const h = window.innerHeight;
      this.canvas.width = w * dpr;
      this.canvas.height = h * dpr;
      this.canvas.style.width = w + 'px';
      this.canvas.style.height = h + 'px';
      this.ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    private updateCardBounds() {
      const card = document.querySelector('.content-card');
      if (card) {
        const rect = card.getBoundingClientRect();
        this.cardLeft = rect.left;
        this.cardAbsBottom = rect.bottom + window.scrollY;
      }
    }

    private computeTransform() {
      if (this.tiles.length === 0) return;

      let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
      for (const tile of this.tiles) {
        for (const v of tile.vertices) {
          if (v.x < minX) minX = v.x;
          if (v.y < minY) minY = v.y;
          if (v.x > maxX) maxX = v.x;
          if (v.y > maxY) maxY = v.y;
        }
      }

      const tileW = maxX - minX;
      const tileH = maxY - minY;
      const canvasW = window.innerWidth;

      // Scale: level 4 bounding box is ~2x level 3, so 3.8 ≈ 1.9×2 maintains same visual tile size.
      const scaleX = canvasW / tileW;
      const scaleY = window.innerHeight / tileH;
      this.scale = Math.max(scaleX, scaleY) * 3.8 * this.tileSizeScale;

      // Center horizontally in viewport
      this.offsetX = -minX * this.scale + (canvasW - tileW * this.scale) / 2;

      // Center vertically over the full document height (for scroll coverage)
      const totalH = document.documentElement.scrollHeight;
      this.offsetY = -minY * this.scale + (totalH - tileH * this.scale) / 2;
    }

    private worldToScreen(p: { x: number; y: number }): { x: number; y: number } {
      return {
        x: p.x * this.scale + this.offsetX,
        y: p.y * this.scale + this.offsetY - this.scrollY,
      };
    }

    private screenToWorld(sx: number, sy: number): { x: number; y: number } {
      return {
        x: (sx - this.offsetX) / this.scale,
        y: (sy + this.scrollY - this.offsetY) / this.scale,
      };
    }

    /**
     * Compute the background gradient color at a given screen position.
     * Accounts for scroll: maps over full document height.
     */
    private getGradientColorAt(sx: number, sy: number): [number, number, number] {
      const w = window.innerWidth;
      const totalH = document.documentElement.scrollHeight;
      const tx = 1 - (sx / w);
      const ty = (sy + this.scrollY) / totalH;
      const t = Math.max(0, Math.min(1, (tx + ty) / 2));
      return lerpColor(this.bgLight, this.bgDark, t);
    }

    /**
     * Compute tile visibility alpha.
     * Tiles visible in the left margin (left of content card) and
     * below the content card (bottom strip).
     *
     * The bottom boundary is an organic parabolic curve:
     * tiles appear higher at the viewport edges, lower in the center.
     * This creates a bowl-shaped footer rather than a flat line.
     */
    private getTileAlpha(sx: number, sy: number): number {
      const fade = this.footerFade;

      // Horizontal alpha (left margin zone)
      let hAlpha = 0;
      if (sx < this.cardLeft) {
        const dist = this.cardLeft - sx;
        hAlpha = dist < fade
          ? this.outlineOpacity * (dist / fade)
          : this.outlineOpacity;
      }

      // Vertical alpha (bottom strip zone) with organic curved boundary
      let vAlpha = 0;
      const cardBottomScreen = this.cardAbsBottom - this.scrollY;
      const w = window.innerWidth;
      const centerX = w / 2;
      // 0 at center, 1 at edges — quadratic for smooth parabolic curve
      const edgeDist = Math.abs(sx - centerX) / centerX;
      const rise = this.footerRise * edgeDist * edgeDist;
      const threshold = cardBottomScreen - rise;

      if (sy > threshold) {
        const dist = sy - threshold;
        vAlpha = dist < fade
          ? this.outlineOpacity * (dist / fade)
          : this.outlineOpacity;
      }

      return Math.max(hAlpha, vAlpha);
    }

    /**
     * Get the hover fade factor for a cooling tile (0 = expired, 1 = full highlight).
     */
    private getCoolingFactor(tileIndex: number): number {
      const startTime = this.coolingTiles.get(tileIndex);
      if (startTime === undefined) return 0;

      const elapsed = (performance.now() - startTime) / 1000;
      if (elapsed < this.hoverHold) return 1;
      if (elapsed < this.hoverHold + this.hoverFade) {
        return 1 - (elapsed - this.hoverHold) / this.hoverFade;
      }
      return 0;
    }

    /**
     * Remove expired entries from the cooling map.
     */
    private cleanCoolingTiles() {
      const now = performance.now();
      const totalMs = (this.hoverHold + this.hoverFade) * 1000;
      for (const [idx, time] of this.coolingTiles) {
        if (now - time >= totalMs) {
          this.coolingTiles.delete(idx);
        }
      }
    }

    /**
     * Compute ripple darkening factor (0–1) for a tile given its world centroid.
     */
    private getRippleFactor(centroid: { x: number; y: number }): number {
      if (this.ripples.length === 0) return 0;
      const now = performance.now();
      let maxFactor = 0;
      for (let i = 0; i < this.ripples.length; i++) {
        const r = this.ripples[i];
        const dx = centroid.x - r.cx;
        const dy = centroid.y - r.cy;
        const screenDist = Math.sqrt(dx * dx + dy * dy) * this.scale;
        if (screenDist > this.rippleRadius) continue;
        const elapsed = (now - r.time) / 1000;
        const arrivalTime = screenDist / this.rippleSpeed;
        const localElapsed = elapsed - arrivalTime;
        if (localElapsed < 0 || localElapsed >= this.rippleFade) continue;
        const timeFactor = 1 - localElapsed / this.rippleFade;
        const distFactor = 1 - screenDist / this.rippleRadius;
        const factor = timeFactor * distFactor;
        if (factor > maxFactor) maxFactor = factor;
      }
      return maxFactor;
    }

    /**
     * Remove ripples whose wavefront + fade have fully expired.
     */
    private cleanRipples() {
      if (this.ripples.length === 0) return;
      const now = performance.now();
      const maxLifeMs = (this.rippleRadius / this.rippleSpeed + this.rippleFade) * 1000;
      this.ripples = this.ripples.filter(r => now - r.time < maxLifeMs);
    }

    private static readonly POP_UP_TIME = 0.04; // seconds — very fast snap

    /**
     * Quadratic ease-out: fast start, decelerating.
     */
    private easeOut(t: number): number {
      const inv = 1 - t;
      return 1 - inv * inv * inv; // cubic — snaps to full faster
    }

    /**
     * Quadratic ease-in: slow start, accelerating.
     */
    private easeIn(t: number): number {
      return t * t;
    }

    /**
     * Get pop animation factor for a tile (0 = no pop, 1 = max pop).
     * Three phases: scale-up (90ms ease-out), hold (while pressed), scale-down (clickDuration ease-in).
     */
    private getPopFactor(tileIndex: number): number {
      const state = this.poppingTiles.get(tileIndex);
      if (!state) return 0;

      const now = performance.now();
      const pressSec = (now - state.pressTime) / 1000;

      // Phase 1: Scale up
      if (pressSec < HatTilingRenderer.POP_UP_TIME) {
        return this.easeOut(pressSec / HatTilingRenderer.POP_UP_TIME);
      }

      // Phase 2: Hold (still pressed, or scale-up just finished and not yet released)
      if (state.releaseTime < 0) return 1;

      // Phase 3: Scale down after release
      const releaseSec = (now - state.releaseTime) / 1000;
      if (releaseSec >= this.clickDuration) return 0;
      return 1 - this.easeIn(releaseSec / this.clickDuration);
    }

    /**
     * Scale screen-space vertices outward from centroid.
     */
    private scaleVertices(
      verts: { x: number; y: number }[],
      center: { x: number; y: number },
      s: number
    ): { x: number; y: number }[] {
      return verts.map(v => ({
        x: center.x + (v.x - center.x) * s,
        y: center.y + (v.y - center.y) * s,
      }));
    }

    /**
     * Play a tiny synthesized pen-click sound.
     */
    private playClickSound() {
      if (!this.audioCtx) {
        this.audioCtx = new AudioContext();
      }
      const ctx = this.audioCtx;
      const now = ctx.currentTime;

      // Short noise burst shaped like a pen click
      const duration = 0.008;
      const bufferSize = Math.ceil(ctx.sampleRate * duration);
      const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
      const data = buffer.getChannelData(0);
      for (let i = 0; i < bufferSize; i++) {
        const t = i / bufferSize;
        // Sharp attack, fast decay envelope
        const envelope = Math.exp(-t * 40);
        data[i] = (Math.random() * 2 - 1) * envelope;
      }

      const source = ctx.createBufferSource();
      source.buffer = buffer;

      // Bandpass filter for a tighter "tick"
      const filter = ctx.createBiquadFilter();
      filter.type = 'bandpass';
      filter.frequency.value = 3000;
      filter.Q.value = 1.5;

      const gain = ctx.createGain();
      gain.gain.value = 0.12;

      source.connect(filter);
      filter.connect(gain);
      gain.connect(ctx.destination);
      source.start(now);
    }

    /**
     * Remove expired pop animations, transfer to cooling for fade-out.
     */
    private cleanPoppingTiles() {
      const now = performance.now();
      const durationMs = this.clickDuration * 1000;
      for (const [idx, state] of this.poppingTiles) {
        // Only clean up tiles that have been released and finished animating
        if (state.releaseTime >= 0 && now - state.releaseTime >= durationMs) {
          this.coolingTiles.set(idx, now);
          this.poppingTiles.delete(idx);
        }
      }
    }

    /**
     * Batched rAF render. Keeps looping while any animation is active.
     */
    private scheduleRender() {
      if (this.pendingRender) return;
      this.pendingRender = true;
      requestAnimationFrame(() => {
        this.pendingRender = false;
        this.cleanCoolingTiles();
        this.cleanPoppingTiles();
        this.cleanRipples();
        this.render();
        if (this.coolingTiles.size > 0 || this.poppingTiles.size > 0 || this.ripples.length > 0) {
          this.scheduleRender();
        }
      });
    }

    /**
     * Find the tile index at a given screen point, or -1 if none.
     * Only checks tiles in the visible left-margin zone.
     */
    private findTileAtScreen(sx: number, sy: number): number {
      if (this.getTileAlpha(sx, sy) < 0.01) return -1;

      const worldPt = this.screenToWorld(sx, sy);
      for (let i = 0; i < this.tiles.length; i++) {
        const tile = this.tiles[i];
        const dx = worldPt.x - tile.centroid.x;
        const dy = worldPt.y - tile.centroid.y;
        if (dx * dx + dy * dy < 25) {
          if (pointInPolygon(worldPt, tile.vertices)) {
            return i;
          }
        }
      }
      return -1;
    }

    /**
     * Light up all tiles along a line segment between two screen points.
     * Samples points along the line and adds unique tiles to the cooling set.
     */
    private interpolateTilesAlongLine(x0: number, y0: number, x1: number, y1: number) {
      const dx = x1 - x0;
      const dy = y1 - y0;
      const dist = Math.sqrt(dx * dx + dy * dy);

      // Sample every ~8 screen pixels along the line
      const steps = Math.max(1, Math.ceil(dist / 8));
      const now = performance.now();
      const seen = new Set<number>();

      for (let s = 0; s <= steps; s++) {
        const t = s / steps;
        const sx = x0 + dx * t;
        const sy = y0 + dy * t;

        const idx = this.findTileAtScreen(sx, sy);
        if (idx !== -1 && !seen.has(idx)) {
          seen.add(idx);
          // Add to cooling (will show as trail), unless it's the current hover target
          if (idx !== this.hoveredTile) {
            this.coolingTiles.set(idx, now);
          }
        }
      }
    }

    private onPointerMove(e: PointerEvent) {
      const sx = e.clientX;
      const sy = e.clientY;

      // Interpolate tiles along the line from previous pointer position
      if (this.lastPointerX >= 0 && this.lastPointerY >= 0) {
        const dx = sx - this.lastPointerX;
        const dy = sy - this.lastPointerY;
        const dist = dx * dx + dy * dy;
        // Only interpolate if we moved more than a few pixels
        if (dist > 64) {
          this.interpolateTilesAlongLine(this.lastPointerX, this.lastPointerY, sx, sy);
        }
      }
      this.lastPointerX = sx;
      this.lastPointerY = sy;

      // Find the tile directly under the cursor
      const found = this.findTileAtScreen(sx, sy);

      if (found !== this.hoveredTile) {
        // Start cooling the old tile
        if (this.hoveredTile !== -1) {
          this.coolingTiles.set(this.hoveredTile, performance.now());
        }
        // If the new tile was cooling, pull it out (it's now active)
        if (found !== -1) {
          this.coolingTiles.delete(found);
        }
        this.hoveredTile = found;
        this.scheduleRender();
      } else if (this.coolingTiles.size > 0) {
        // Even if hovered tile didn't change, interpolation may have added new cooling tiles
        this.scheduleRender();
      }
    }

    private onPointerLeave() {
      if (this.hoveredTile !== -1) {
        this.coolingTiles.set(this.hoveredTile, performance.now());
        this.hoveredTile = -1;
      }
      // Release held tile if pointer leaves the window
      if (this.heldTile !== -1) {
        const state = this.poppingTiles.get(this.heldTile);
        if (state && state.releaseTime < 0) {
          state.releaseTime = performance.now();
        }
        this.heldTile = -1;
      }
      this.lastPointerX = -1;
      this.lastPointerY = -1;
      this.scheduleRender();
    }

    private onPointerDown(e: PointerEvent) {
      const idx = this.findTileAtScreen(e.clientX, e.clientY);
      if (idx === -1) return;

      // Release any previously held tile
      if (this.heldTile !== -1 && this.heldTile !== idx) {
        const prev = this.poppingTiles.get(this.heldTile);
        if (prev && prev.releaseTime < 0) {
          prev.releaseTime = performance.now();
        }
      }

      // Subtle click sound
      this.playClickSound();

      // Easter egg: increment click counter
      this.clickCount++;
      if (this.clickCounterEl) {
        this.clickCounterEl.textContent = String(this.clickCount);
      }

      // Start (or restart) the pop animation — held until pointerup
      this.coolingTiles.delete(idx);
      const now = performance.now();
      this.poppingTiles.set(idx, { pressTime: now, releaseTime: -1 });
      this.heldTile = idx;

      // Spawn ripple from the clicked tile's centroid
      const tile = this.tiles[idx];
      this.ripples.push({ cx: tile.centroid.x, cy: tile.centroid.y, time: now });

      // Notify Galton board
      document.dispatchEvent(new CustomEvent('tile-click'));

      this.scheduleRender();
    }

    private onPointerUp() {
      if (this.heldTile === -1) return;
      const state = this.poppingTiles.get(this.heldTile);
      if (state && state.releaseTime < 0) {
        state.releaseTime = performance.now();
      }
      this.heldTile = -1;
      this.scheduleRender();
    }

    private render() {
      const ctx = this.ctx;
      const canvasW = window.innerWidth;
      const canvasH = window.innerHeight;

      ctx.clearRect(0, 0, canvasW, canvasH);

      // Pre-compute popping tile data for clip exclusion + Pass 2
      const popData: Array<{
        i: number;
        screenCentroid: { x: number; y: number };
        alpha: number;
        popFactor: number;
        scaledVerts: { x: number; y: number }[];
      }> = [];

      if (this.poppingTiles.size > 0) {
        for (const [i] of this.poppingTiles) {
          const tile = this.tiles[i];
          const screenCentroid = this.worldToScreen(tile.centroid);
          const alpha = this.getTileAlpha(screenCentroid.x, screenCentroid.y);
          const popFactor = this.getPopFactor(i);
          if (alpha < 0.01 || popFactor < 0.001) continue;
          const currentScale = 1 + (this.clickScale - 1) * popFactor;
          const screenVerts = tile.vertices.map(v => this.worldToScreen(v));
          const scaledVerts = this.scaleVertices(screenVerts, screenCentroid, currentScale);
          popData.push({ i, screenCentroid, alpha, popFactor, scaledVerts });
        }
      }

      // Set up clip exclusion: canvas rect with pop polygon holes (evenodd).
      // This prevents Pass 1 outlines from being drawn inside pop regions.
      if (popData.length > 0) {
        ctx.save();
        ctx.beginPath();
        ctx.rect(0, 0, canvasW, canvasH);
        for (const pop of popData) {
          const verts = pop.scaledVerts;
          ctx.moveTo(verts[verts.length - 1].x, verts[verts.length - 1].y);
          for (let j = verts.length - 2; j >= 0; j--) {
            ctx.lineTo(verts[j].x, verts[j].y);
          }
          ctx.closePath();
        }
        ctx.clip('evenodd');
      }

      // ─── Pass 1: Regular tiles (clipped around pop regions) ───
      const cardBottomScreen = this.cardAbsBottom - this.scrollY;
      for (let i = 0; i < this.tiles.length; i++) {
        const tile = this.tiles[i];

        // Early cull: check centroid before transforming all vertices
        const screenCentroid = this.worldToScreen(tile.centroid);
        // Skip tiles outside both visible zones (left margin + bottom strip with organic rise)
        if (screenCentroid.x > this.cardLeft + 50 && screenCentroid.y < cardBottomScreen - this.footerRise - 50) continue;
        if (screenCentroid.y < -100 || screenCentroid.y > canvasH + 100) continue;

        const alpha = this.getTileAlpha(screenCentroid.x, screenCentroid.y);
        if (alpha < 0.01) continue;

        // Skip popping tiles in Pass 1 — Pass 2 handles them
        if (this.poppingTiles.has(i)) continue;

        const screenVerts = tile.vertices.map(v => this.worldToScreen(v));

        const isHovered = i === this.hoveredTile;
        const coolingFactor = this.getCoolingFactor(i);
        const rippleFactor = this.getRippleFactor(tile.centroid);

        ctx.beginPath();
        ctx.moveTo(screenVerts[0].x, screenVerts[0].y);
        for (let j = 1; j < screenVerts.length; j++) {
          ctx.lineTo(screenVerts[j].x, screenVerts[j].y);
        }
        ctx.closePath();

        // Hover highlight + ripple shimmer (combined)
        const hoverFactor = isHovered ? 1 : coolingFactor;
        const combinedFactor = Math.min(1, hoverFactor + rippleFactor);
        if (combinedFactor > 0) {
          const bgColor = this.getGradientColorAt(screenCentroid.x, screenCentroid.y);
          const darkened = darkenColor(bgColor, this.hoverDarken);
          const hoverAlpha = alpha / this.outlineOpacity;
          ctx.fillStyle = `rgba(${darkened[0]}, ${darkened[1]}, ${darkened[2]}, ${hoverAlpha * 0.5 * combinedFactor})`;
          ctx.fill();
        }

        ctx.strokeStyle = this.outlineColor;
        ctx.globalAlpha = alpha;
        ctx.lineWidth = 0.5;
        ctx.stroke();
        ctx.globalAlpha = 1;
      }

      // Restore clip
      if (popData.length > 0) {
        ctx.restore();
      }

      // ─── Pass 2: Popping tiles (drawn into clean area) ───
      for (const pop of popData) {
        const { scaledVerts, screenCentroid, alpha, popFactor } = pop;

        ctx.beginPath();
        ctx.moveTo(scaledVerts[0].x, scaledVerts[0].y);
        for (let j = 1; j < scaledVerts.length; j++) {
          ctx.lineTo(scaledVerts[j].x, scaledVerts[j].y);
        }
        ctx.closePath();

        // Opaque fill — gradient-matched, darkened
        const bgColor = this.getGradientColorAt(screenCentroid.x, screenCentroid.y);
        const darkened = darkenColor(bgColor, this.clickDarken * popFactor);
        ctx.fillStyle = `rgb(${darkened[0]}, ${darkened[1]}, ${darkened[2]})`;
        ctx.globalAlpha = alpha / this.outlineOpacity;
        ctx.fill();

        // Outline on top
        ctx.strokeStyle = this.outlineColor;
        ctx.globalAlpha = alpha;
        ctx.lineWidth = 0.5;
        ctx.stroke();
        ctx.globalAlpha = 1;
      }
    }
  }

  const canvas = document.getElementById('hat-tiling-canvas') as HTMLCanvasElement;
  if (canvas) {
    new HatTilingRenderer(canvas);
  }
</script>

