    z-index: 10;
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: var(--color-text-primary);
    opacity: 0.25;
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  .tile-click-counter:empty {
    display: none;
  }
</style>
