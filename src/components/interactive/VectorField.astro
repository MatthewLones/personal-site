---
---
<div class="vector-field-container">
  <canvas id="vector-field-canvas" class="vector-field-canvas"></canvas>

  <div class="vf-dashboard">
    <div class="vf-mode-bar" role="radiogroup" aria-label="Interaction mode">
      <button class="vf-mode-opt" data-mode="push">push</button>
      <button class="vf-mode-opt" data-mode="combing">flow</button>
      <button class="vf-mode-opt" data-mode="radial">radial</button>
      <button class="vf-mode-opt active" data-mode="trace">trace</button>
    </div>

    <div class="vf-field-select">
      <label class="vf-label" for="vf-fn-select">field</label>
      <select id="vf-fn-select" class="vf-select"></select>
    </div>

    <div class="vf-custom-input" id="vf-custom-wrap" hidden>
      <label class="vf-label" for="vf-custom-fn">f(x, y) =</label>
      <div class="vf-input-row">
        <input
          type="text"
          id="vf-custom-fn"
          class="vf-input"
          placeholder="sin(x*0.05) * cos(y*0.03)"
          spellcheck="false"
          autocomplete="off"
        />
        <button id="vf-custom-apply" class="vf-apply-btn">go</button>
      </div>
      <div class="vf-error" id="vf-error" hidden></div>
      <div class="vf-help">vars: x, y, r, theta, pi, e</div>
    </div>
  </div>
</div>

<script>
  import {
    generateField,
    generateBlobShape,
    randomPreset,
    computeInteractionTarget,
    computePushTarget,
    stepField,
    stepBall,
    buildCellHash,
    transitionCellsFromLeaves,
    spawnWindLeaves,
    spawnPerimeterLeaves,
    stepLeaves,
    pickWindOrigin,
    angleDiff,
    isInsideBlob,
    FIELD_PRESETS,
    type VectorFieldCell,
    type Vec2,
    type InteractionMode,
    type VectorFieldConfig,
    type BlobShape,
    type TraceBall,
    type WindTransition,
    type LeafParticle,
  } from '../../lib/vector-field';

  import {
    parseExpression,
    compileExpression,
    ParseError,
  } from '../../lib/expr-parser';

  class VectorFieldRenderer {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private container: HTMLElement;
    private modeButtons: NodeListOf<HTMLButtonElement>;

    // Overlay canvas for ball rendering (full document, position: absolute)
    private overlay!: HTMLCanvasElement;
    private overlayCtx!: CanvasRenderingContext2D;
    private overlayW = 0;
    private overlayH = 0;

    private cells: VectorFieldCell[] = [];
    private config!: VectorFieldConfig;
    private blob!: BlobShape;
    private mode: InteractionMode = 'trace';

    // Native cursor SVGs for trace mode (normal + click animation states)
    private cursorNormal = '';
    private cursorPressed = '';
    private cursorBounce = '';
    private cursorAnimGen = 0;

    // Audio
    private audioCtx: AudioContext | null = null;

    // Tokens
    private arrowColor = '#3a3020';
    private arrowLength = 10;
    private arrowHeadSize = 3;
    private arrowWidth = 1;
    private gridSpacing = 12;
    private fieldRadius = 250;
    private influenceRadius = 70;
    private springK = 120;
    private damping = 16;
    private pushContact = 4;
    private pushStrength = 0.8;
    private ballRadius = 3;
    private ballColor = '#3a3020';
    private ballColorRGB: [number, number, number] = [58, 48, 32];
    private ballSpeed = 120;
    private ballGravity = 200;
    private ballTrailMax = 30;

    // Wind transition tokens
    private windSpeed = 650;
    private leafSpawnRate = 6;
    private leafDecayRate = 0.15;
    private leafMaxCount = 280;

    // State
    private balls: TraceBall[] = [];
    private ballShades: [number, number, number][] = [];
    private pendingRender = false;
    private isAnimating = false;
    private lastFrameTime = 0;
    private cursorPos: Vec2 | null = null;
    private lastCursorPos: Vec2 | null = null;
    private cursorInField = false;
    private dpr = 1;
    private canvasW = 0;
    private canvasH = 0;

    // Wind transition state
    private windTransition: WindTransition | null = null;
    private leaves: LeafParticle[] = [];
    private cellHash: Map<string, number[]> = new Map();

    // Dashboard elements
    private selectEl!: HTMLSelectElement;
    private customWrap!: HTMLElement;
    private customInput!: HTMLInputElement;
    private customApply!: HTMLButtonElement;
    private errorEl!: HTMLElement;
    private currentPresetId = '';

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;
      this.container = canvas.parentElement!;
      this.modeButtons = this.container.querySelectorAll<HTMLButtonElement>('.vf-mode-opt');
      this.selectEl = this.container.querySelector<HTMLSelectElement>('#vf-fn-select')!;
      this.customWrap = this.container.querySelector<HTMLElement>('#vf-custom-wrap')!;
      this.customInput = this.container.querySelector<HTMLInputElement>('#vf-custom-fn')!;
      this.customApply = this.container.querySelector<HTMLButtonElement>('#vf-custom-apply')!;
      this.errorEl = this.container.querySelector<HTMLElement>('#vf-error')!;

      this.readTokens();
      this.buildCursorStates();
      this.canvas.style.cursor = this.cursorNormal;
      this.populateDropdown();
      this.createOverlay();
      this.init();
    }

    private readTokens(): void {
      const s = getComputedStyle(document.documentElement);
      const str = (name: string) => s.getPropertyValue(name).trim();
      const num = (name: string, fallback: number) => {
        const v = parseFloat(str(name));
        return isNaN(v) ? fallback : v;
      };

      const color = str('--vf-arrow-color');
      if (color) this.arrowColor = color;
      this.arrowLength = num('--vf-arrow-length', this.arrowLength);
      this.arrowHeadSize = num('--vf-arrow-head-size', this.arrowHeadSize);
      this.arrowWidth = num('--vf-arrow-width', this.arrowWidth);
      this.gridSpacing = num('--vf-grid-spacing', this.gridSpacing);
      this.fieldRadius = num('--vf-field-radius', this.fieldRadius);
      this.influenceRadius = num('--vf-influence-radius', this.influenceRadius);
      this.springK = num('--vf-spring-k', this.springK);
      this.damping = num('--vf-damping', this.damping);
      this.pushContact = num('--vf-push-contact', this.pushContact);
      this.pushStrength = num('--vf-push-strength', this.pushStrength);
      this.ballRadius = num('--vf-ball-radius', this.ballRadius);
      const ballColor = str('--vf-ball-color');
      if (ballColor) this.ballColor = ballColor;
      const hex = this.ballColor.replace('#', '');
      if (hex.length === 6) {
        this.ballColorRGB = [
          parseInt(hex.slice(0, 2), 16),
          parseInt(hex.slice(2, 4), 16),
          parseInt(hex.slice(4, 6), 16),
        ];
      }
      this.ballSpeed = num('--vf-ball-speed', this.ballSpeed);
      this.ballGravity = num('--vf-ball-gravity', this.ballGravity);
      this.ballTrailMax = num('--vf-ball-trail', this.ballTrailMax);

      // Wind transition tokens
      this.windSpeed = num('--vf-wind-speed', this.windSpeed);
      this.leafSpawnRate = num('--vf-leaf-spawn-rate', this.leafSpawnRate);
      this.leafDecayRate = num('--vf-leaf-decay-rate', this.leafDecayRate);
      this.leafMaxCount = num('--vf-leaf-max-count', this.leafMaxCount);
    }

    private populateDropdown(): void {
      // Pick a random initial preset
      const initial = randomPreset();
      this.currentPresetId = initial.id;

      for (const preset of FIELD_PRESETS) {
        const opt = document.createElement('option');
        opt.value = preset.id;
        opt.textContent = `${preset.label}: ${preset.expression}`;
        if (preset.id === initial.id) opt.selected = true;
        this.selectEl.appendChild(opt);
      }

      // Add custom option
      const customOpt = document.createElement('option');
      customOpt.value = 'custom';
      customOpt.textContent = 'custom...';
      this.selectEl.appendChild(customOpt);
    }

    /** Build native CSS cursor URIs at three scales for click animation. */
    private buildCursorStates(): void {
      const c = this.arrowColor.replace('#', '%23');
      const makeSvg = (scale: number) => {
        const p = (v: number) => (9 + (v - 9) * scale).toFixed(1);
        return `<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 18 18' fill='none'><line x1='${p(2)}' y1='9' x2='${p(6.5)}' y2='9' stroke='${c}' stroke-width='1.2' stroke-linecap='round'/><line x1='${p(11.5)}' y1='9' x2='${p(16)}' y2='9' stroke='${c}' stroke-width='1.2' stroke-linecap='round'/><line x1='9' y1='${p(2)}' x2='9' y2='${p(6.5)}' stroke='${c}' stroke-width='1.2' stroke-linecap='round'/><line x1='9' y1='${p(11.5)}' x2='9' y2='${p(16)}' stroke='${c}' stroke-width='1.2' stroke-linecap='round'/></svg>`;
      };
      const uri = (scale: number) => `url("data:image/svg+xml,${makeSvg(scale)}") 9 9, crosshair`;
      this.cursorNormal = uri(1);
      this.cursorPressed = uri(0.65);
      this.cursorBounce = uri(1.12);
    }

    /** Animate the native cursor: shrink → bounce → normal. */
    private animateCursor(): void {
      const gen = ++this.cursorAnimGen;
      this.canvas.style.cursor = this.cursorPressed;
      setTimeout(() => {
        if (this.cursorAnimGen === gen && this.mode === 'trace')
          this.canvas.style.cursor = this.cursorBounce;
      }, 70);
      setTimeout(() => {
        if (this.cursorAnimGen === gen && this.mode === 'trace')
          this.canvas.style.cursor = this.cursorNormal;
      }, 150);
    }

    /** Play a soft descending-tone "plop" for ball drops. */
    private playDropSound(): void {
      if (!this.audioCtx) {
        this.audioCtx = new AudioContext();
      }
      const ctx = this.audioCtx;
      const now = ctx.currentTime;

      const osc = ctx.createOscillator();
      osc.type = 'sine';
      osc.frequency.setValueAtTime(440, now);
      osc.frequency.exponentialRampToValueAtTime(160, now + 0.08);

      const gain = ctx.createGain();
      gain.gain.setValueAtTime(0.04, now);
      gain.gain.exponentialRampToValueAtTime(0.001, now + 0.09);

      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.start(now);
      osc.stop(now + 0.09);
    }

    private createOverlay(): void {
      this.overlay = document.createElement('canvas');
      this.overlay.style.cssText = 'position:absolute;top:0;left:0;pointer-events:none;z-index:1';
      const pageGrid = document.querySelector('.page-grid');
      if (pageGrid) {
        pageGrid.parentElement!.insertBefore(this.overlay, pageGrid);
      } else {
        document.body.appendChild(this.overlay);
      }
      this.overlayCtx = this.overlay.getContext('2d')!;
      this.sizeOverlay();
      window.addEventListener('resize', () => this.sizeOverlay());
    }

    private sizeOverlay(): void {
      this.dpr = window.devicePixelRatio || 1;
      this.overlayW = document.documentElement.scrollWidth;
      this.overlayH = document.documentElement.scrollHeight;
      this.overlay.style.width = this.overlayW + 'px';
      this.overlay.style.height = this.overlayH + 'px';
      this.overlay.width = this.overlayW * this.dpr;
      this.overlay.height = this.overlayH * this.dpr;
      this.overlayCtx.setTransform(this.dpr, 0, 0, this.dpr, 0, 0);
    }

    private init(): void {
      this.setupCanvas();
      this.generateCells();
      this.bindEvents();
      this.scheduleRender();
      window.dispatchEvent(new CustomEvent('component-ready', { detail: { id: 'vector-field' } }));
    }

    private setupCanvas(): void {
      this.dpr = window.devicePixelRatio || 1;
      const rect = this.container.getBoundingClientRect();
      const w = rect.width;
      const h = this.fieldRadius * 2 + 60;

      this.canvasW = w;
      this.canvasH = h;
      this.canvas.width = w * this.dpr;
      this.canvas.height = h * this.dpr;
      this.canvas.style.width = w + 'px';
      this.canvas.style.height = h + 'px';
      this.ctx.setTransform(this.dpr, 0, 0, this.dpr, 0, 0);
    }

    private generateCells(): void {
      const cx = this.canvasW * 0.55;
      const cy = this.canvasH * 0.58;

      this.config = {
        gridSpacing: this.gridSpacing,
        radius: this.fieldRadius,
        center: { x: cx, y: cy },
      };

      this.blob = generateBlobShape({ x: cx, y: cy }, this.fieldRadius);

      const preset = FIELD_PRESETS.find((p) => p.id === this.currentPresetId);
      const initialFn = preset ? preset.fn : FIELD_PRESETS[0].fn;
      this.cells = generateField(this.config, this.blob, initialFn);
      this.cellHash = buildCellHash(this.cells, this.gridSpacing);
    }

    private bindEvents(): void {
      this.canvas.addEventListener('pointermove', (e) => this.onPointerMove(e), { passive: true });
      this.canvas.addEventListener('pointerdown', (e) => this.onPointerDown(e));
      this.canvas.addEventListener('pointerleave', () => this.onPointerLeave());
      this.canvas.addEventListener('pointerenter', (e) => this.onPointerEnter(e));
      this.modeButtons.forEach((btn) => {
        btn.addEventListener('click', () => this.onModeSelect(btn.dataset.mode as InteractionMode));
      });

      // Dropdown: field function selection
      this.selectEl.addEventListener('change', () => this.onFieldSelect());

      // Custom input: apply on Enter or button click
      this.customInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') this.onCustomApply();
      });
      this.customApply.addEventListener('click', () => this.onCustomApply());

      const ro = new ResizeObserver(() => {
        const rect = this.container.getBoundingClientRect();
        if (Math.abs(rect.width - this.canvasW) < 1) return;
        this.setupCanvas();
        this.generateCells();
        this.scheduleRender();
      });
      ro.observe(this.container);
    }

    // ─── Field selection ────────────────────────────────────

    private onFieldSelect(): void {
      const value = this.selectEl.value;

      if (value === 'custom') {
        this.customWrap.hidden = false;
        this.customInput.focus();
        return;
      }

      this.customWrap.hidden = true;
      this.errorEl.hidden = true;

      const preset = FIELD_PRESETS.find((p) => p.id === value);
      if (!preset || preset.id === this.currentPresetId) return;

      this.currentPresetId = preset.id;
      this.startFieldTransition(preset.fn);
    }

    private onCustomApply(): void {
      const input = this.customInput.value.trim();
      if (!input) return;

      try {
        const ast = parseExpression(input);
        const compiled = compileExpression(ast);

        // Build a field function from the compiled expression
        const customFn = (pos: Vec2, center: Vec2): number => {
          const dx = pos.x - center.x;
          const dy = pos.y - center.y;
          const result = compiled({
            x: dx, y: dy,
            r: Math.sqrt(dx * dx + dy * dy),
            theta: Math.atan2(dy, dx),
            pi: Math.PI, e: Math.E,
          });
          return isFinite(result) ? result : 0;
        };

        // Test the function on a sample point before committing
        customFn({ x: 100, y: 100 }, { x: 0, y: 0 });

        this.errorEl.hidden = true;
        this.currentPresetId = 'custom';
        this.startFieldTransition(customFn);
      } catch (err) {
        this.errorEl.textContent = err instanceof ParseError
          ? err.message
          : 'Invalid expression';
        this.errorEl.hidden = false;
      }
    }

    // ─── Wind transition ────────────────────────────────────

    private startFieldTransition(newFn: (pos: Vec2, center: Vec2) => number): void {
      const viewW = window.innerWidth;
      const viewH = window.innerHeight;
      const scrollY = window.scrollY;

      // Pick a random origin along the top/left/bottom viewport edges
      const origin = pickWindOrigin(viewW, viewH, scrollY);

      // Direction: from origin toward the far side of the viewport
      const targetX = viewW + 100;
      const targetY = scrollY + viewH / 2;
      const dx = targetX - origin.x;
      const dy = targetY - origin.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const direction: Vec2 = { x: dx / dist, y: dy / dist };

      this.windTransition = {
        active: true,
        startTime: performance.now(),
        origin,
        direction,
        newAngleFn: newFn,
        transitioned: new Set(),
      };

      this.leaves = [];

      if (!this.isAnimating) {
        this.isAnimating = true;
        this.lastFrameTime = performance.now();
        this.scheduleRender();
      }
    }

    // ─── Coordinate transforms ───────────────────────────────

    private clientToField(clientX: number, clientY: number): Vec2 {
      const rect = this.canvas.getBoundingClientRect();
      return {
        x: clientX - rect.left,
        y: clientY - rect.top,
      };
    }

    /** Get the offset to convert field-local coords to page coords. */
    private getFieldOffset(): Vec2 {
      const rect = this.canvas.getBoundingClientRect();
      return {
        x: rect.left + window.scrollX,
        y: rect.top + window.scrollY,
      };
    }

    // ─── Per-ball shade generation ───────────────────────────

    private generateShade(): [number, number, number] {
      const base = this.ballColorRGB;
      const clamp = (v: number) => Math.max(0, Math.min(255, v));
      return [
        clamp(base[0] + Math.round((Math.random() - 0.5) * 30)),
        clamp(base[1] + Math.round((Math.random() - 0.5) * 30)),
        clamp(base[2] + Math.round((Math.random() - 0.5) * 30)),
      ];
    }

    // ─── Pointer events ─────────────────────────────────────

    private onPointerMove(e: PointerEvent): void {
      const pos = this.clientToField(e.clientX, e.clientY);
      this.cursorPos = pos;
      this.cursorInField = isInsideBlob(pos, this.blob);

      if (this.mode === 'trace') return;

      const prevPos = this.lastCursorPos;
      this.lastCursorPos = pos;

      if (!prevPos) return;

      const dx = pos.x - prevPos.x;
      const dy = pos.y - prevPos.y;
      const dist = Math.sqrt(dx * dx + dy * dy);

      if (dist < 2) return;

      const delta: Vec2 = { x: dx, y: dy };
      this.interpolateAlongLine(prevPos, pos, delta);

      if (!this.isAnimating) {
        this.isAnimating = true;
        this.lastFrameTime = performance.now();
        this.scheduleRender();
      }
    }

    private interpolateAlongLine(from: Vec2, to: Vec2, delta: Vec2): void {
      const dx = to.x - from.x;
      const dy = to.y - from.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const step = 8;
      const steps = Math.max(1, Math.round(dist / step));

      for (let i = 1; i <= steps; i++) {
        const t = i / steps;
        const samplePos: Vec2 = {
          x: from.x + dx * t,
          y: from.y + dy * t,
        };
        this.updateCellTargets(samplePos, delta);
      }
    }

    private onPointerDown(e: PointerEvent): void {
      if (this.mode !== 'trace') return;
      const fieldPos = this.clientToField(e.clientX, e.clientY);
      const offset = this.getFieldOffset();
      this.balls.push({
        pos: { x: fieldPos.x + offset.x, y: fieldPos.y + offset.y },
        vel: { x: 0, y: 0 },
        active: true,
        trail: [],
      });
      this.ballShades.push(this.generateShade());

      this.animateCursor();
      this.playDropSound();

      if (!this.isAnimating) {
        this.isAnimating = true;
        this.lastFrameTime = performance.now();
        this.scheduleRender();
      }
    }

    private onPointerEnter(e: PointerEvent): void {
      const pos = this.clientToField(e.clientX, e.clientY);
      this.lastCursorPos = pos;
      this.cursorPos = pos;
    }

    private onPointerLeave(): void {
      this.cursorInField = false;
      this.cursorPos = null;
      this.lastCursorPos = null;
    }

    private onModeSelect(mode: InteractionMode): void {
      if (mode === this.mode) return;
      this.mode = mode;

      this.modeButtons.forEach((btn) => {
        btn.classList.toggle('active', btn.dataset.mode === mode);
      });

      this.canvas.style.cursor = mode === 'trace' ? this.cursorNormal : '';

      if (this.mode === 'radial' && this.cursorPos && this.cursorInField) {
        this.updateCellTargets(this.cursorPos, { x: 0, y: 0 });
        if (!this.isAnimating) {
          this.isAnimating = true;
          this.lastFrameTime = performance.now();
          this.scheduleRender();
        }
      }
    }

    private updateCellTargets(cursorPos: Vec2, delta: Vec2): void {
      const halfLen = this.arrowLength / 2;

      for (let i = 0; i < this.cells.length; i++) {
        const cell = this.cells[i];

        if (this.mode === 'push') {
          const angleDelta = computePushTarget(
            cell,
            cursorPos,
            delta,
            halfLen,
            this.pushContact,
            this.pushStrength,
          );
          if (angleDelta !== null) {
            cell.targetAngle += angleDelta;
          }
        } else {
          const result = computeInteractionTarget(
            cell,
            cursorPos,
            delta,
            this.mode,
            this.influenceRadius,
          );
          if (result) {
            const diff = angleDiff(cell.targetAngle, result.angle);
            cell.targetAngle += diff * result.influence;
          }
        }
      }
    }

    // ─── Animation loop ─────────────────────────────────────

    private scheduleRender(): void {
      if (this.pendingRender) return;
      this.pendingRender = true;

      requestAnimationFrame((t) => {
        this.pendingRender = false;
        const dt = Math.min((t - this.lastFrameTime) / 1000, 0.05);
        this.lastFrameTime = t;

        const stillMoving = stepField(this.cells, dt, this.springK, this.damping);

        // Wind transition — leaf-driven cell transitions
        let windActive = false;
        const wt = this.windTransition;
        const fieldOffset = this.getFieldOffset();
        if (wt?.active) {
          // Dual-spawn: off-screen leaves from all viewport edges +
          // perimeter leaves for guaranteed blob edge coverage
          const room = this.leafMaxCount - this.leaves.length;
          if (room > 0) {
            const perimeterActive = wt.transitioned.size >= Math.min(50, Math.ceil(this.cells.length * 0.04));

            if (perimeterActive) {
              // Phase B: split budget between off-screen and perimeter
              const offscreenCount = Math.min(Math.ceil(this.leafSpawnRate * 0.5), room);
              const spawned = spawnWindLeaves(
                wt, this.windSpeed, offscreenCount, 200, this.blob, fieldOffset,
              );
              this.leaves.push(...spawned);

              const perimeterRoom = this.leafMaxCount - this.leaves.length;
              if (perimeterRoom > 0) {
                const perimeterCount = Math.min(Math.ceil(this.leafSpawnRate * 0.5), perimeterRoom);
                const pLeaves = spawnPerimeterLeaves(
                  this.blob, wt.newAngleFn, this.windSpeed, perimeterCount, fieldOffset,
                );
                this.leaves.push(...pLeaves);
              }
            } else {
              // Phase A: full off-screen spawning
              const count = Math.min(Math.ceil(this.leafSpawnRate), room);
              const spawned = spawnWindLeaves(
                wt, this.windSpeed, count, 200, this.blob, fieldOffset,
              );
              this.leaves.push(...spawned.slice(0, room));
            }
          }

          // End when all cells have been transitioned
          if (wt.transitioned.size >= this.cells.length) {
            wt.active = false;
          }

          // Safety net: once >97% of cells are transitioned,
          // force the remaining scattered cells immediately.
          // With perimeter spawning, this rarely triggers.
          if (wt.active && wt.transitioned.size >= this.cells.length * 0.97) {
            for (let i = 0; i < this.cells.length; i++) {
              if (!wt.transitioned.has(i)) {
                const newAngle = wt.newAngleFn(this.cells[i].pos, this.config.center);
                this.cells[i].restAngle = newAngle;
                this.cells[i].targetAngle = newAngle;
                wt.transitioned.add(i);
              }
            }
            wt.active = false;
          }

          // Fallback: force-transition remaining cells after 5s
          const elapsed = (t - wt.startTime) / 1000;
          if (elapsed > 5 && wt.transitioned.size < this.cells.length) {
            for (let i = 0; i < this.cells.length; i++) {
              if (!wt.transitioned.has(i)) {
                const newAngle = wt.newAngleFn(this.cells[i].pos, this.config.center);
                this.cells[i].restAngle = newAngle;
                this.cells[i].targetAngle = newAngle;
                wt.transitioned.add(i);
              }
            }
            wt.active = false;
          }
          windActive = true;
        }

        // Step leaves — three-phase: approach, penetrate, follow field
        const windDir = wt ? wt.direction : { x: 1, y: 0 };
        const activeFn = wt ? wt.newAngleFn : null;
        const leavesAlive = stepLeaves(
          this.leaves, dt, this.leafDecayRate,
          activeFn, this.config.center, fieldOffset,
          windDir, this.windSpeed, this.blob,
        );

        // Leaf-driven cell transitions
        if (wt?.active) {
          transitionCellsFromLeaves(
            this.leaves, this.cells, this.cellHash, this.gridSpacing,
            this.config.center, fieldOffset, wt.newAngleFn, wt.transitioned,
          );
        }

        if (leavesAlive === 0 && !windActive) {
          this.leaves = [];
        }

        // Step all balls (positions in page coords)
        const pageBottom = this.overlayH;

        for (let b = 0; b < this.balls.length; b++) {
          const ball = this.balls[b];
          if (!ball.active) continue;
          stepBall(
            ball, this.cells, this.blob, fieldOffset, dt,
            this.ballSpeed, this.ballGravity,
            this.gridSpacing * 2, this.ballTrailMax,
          );
          if (ball.pos.y > pageBottom) ball.active = false;
        }

        // Prune dead balls (keep shades in sync)
        const newBalls: TraceBall[] = [];
        const newShades: [number, number, number][] = [];
        for (let i = 0; i < this.balls.length; i++) {
          if (this.balls[i].active) {
            newBalls.push(this.balls[i]);
            newShades.push(this.ballShades[i]);
          }
        }
        this.balls = newBalls;
        this.ballShades = newShades;

        this.render();
        this.renderOverlay();

        const anyBalls = this.balls.length > 0;
        if (stillMoving || anyBalls || windActive || leavesAlive > 0) {
          this.scheduleRender();
        } else {
          this.isAnimating = false;
        }
      });
    }

    // ─── Rendering ──────────────────────────────────────────

    private render(): void {
      const ctx = this.ctx;
      ctx.clearRect(0, 0, this.canvasW, this.canvasH);

      const halfLen = this.arrowLength / 2;
      const headSize = this.arrowHeadSize;
      const headAngle = Math.PI * 0.8;

      ctx.beginPath();
      for (let i = 0; i < this.cells.length; i++) {
        const cell = this.cells[i];
        const px = cell.pos.x;
        const py = cell.pos.y;
        const cos = Math.cos(cell.angle);
        const sin = Math.sin(cell.angle);

        const x1 = px - cos * halfLen;
        const y1 = py - sin * halfLen;
        const x2 = px + cos * halfLen;
        const y2 = py + sin * halfLen;
        ctx.moveTo(x1, y1);
        ctx.lineTo(x2, y2);

        const hx1 = x2 + Math.cos(cell.angle + headAngle) * headSize;
        const hy1 = y2 + Math.sin(cell.angle + headAngle) * headSize;
        const hx2 = x2 + Math.cos(cell.angle - headAngle) * headSize;
        const hy2 = y2 + Math.sin(cell.angle - headAngle) * headSize;
        ctx.moveTo(hx1, hy1);
        ctx.lineTo(x2, y2);
        ctx.lineTo(hx2, hy2);
      }
      ctx.strokeStyle = this.arrowColor;
      ctx.lineWidth = this.arrowWidth;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.stroke();
    }

    /** Render leaves and balls on the full-page overlay canvas (page coords). */
    private renderOverlay(): void {
      const oc = this.overlayCtx;
      oc.clearRect(0, 0, this.overlayW, this.overlayH);

      const scrollY = window.scrollY;
      const viewTop = scrollY - 50;
      const viewBottom = scrollY + window.innerHeight + 50;

      // 1. Leaves (page coords, rendered across entire screen)
      for (let i = 0; i < this.leaves.length; i++) {
        const leaf = this.leaves[i];
        if (leaf.life <= 0) continue;
        if (leaf.pos.y < viewTop || leaf.pos.y > viewBottom) continue;

        oc.save();
        oc.translate(leaf.pos.x, leaf.pos.y);
        oc.rotate(leaf.angle);
        // Hold full opacity for most of the journey, only fade in last 33% of life
        oc.globalAlpha = Math.min(1, leaf.life * 3) * 0.55;
        oc.fillStyle = this.arrowColor;

        if (leaf.variant === 0) {
          oc.beginPath();
          oc.ellipse(0, 0, 1.5 * leaf.size, 3 * leaf.size, 0, 0, Math.PI * 2);
          oc.fill();
        } else if (leaf.variant === 1) {
          oc.beginPath();
          oc.moveTo(0, -3 * leaf.size);
          oc.quadraticCurveTo(2 * leaf.size, 0, 0, 3 * leaf.size);
          oc.quadraticCurveTo(-2 * leaf.size, 0, 0, -3 * leaf.size);
          oc.fill();
        } else {
          oc.beginPath();
          oc.arc(0, 0, 1.2 * leaf.size, 0, Math.PI * 2);
          oc.fill();
        }

        oc.restore();
      }

      // 2. Balls (page coords)
      if (this.balls.length === 0) return;

      oc.lineCap = 'butt';

      for (let b = 0; b < this.balls.length; b++) {
        const ball = this.balls[b];
        if (!ball.active || ball.trail.length < 2) continue;

        const shade = this.ballShades[b];
        const trail = ball.trail;
        const len = trail.length;

        for (let i = 1; i < len; i++) {
          const p0 = trail[i - 1];
          const p1 = trail[i];

          if ((p0.y < viewTop && p1.y < viewTop) || (p0.y > viewBottom && p1.y > viewBottom)) continue;

          const t = i / len;
          oc.beginPath();
          oc.moveTo(p0.x, p0.y);
          oc.lineTo(p1.x, p1.y);
          oc.strokeStyle = `rgba(${shade[0]},${shade[1]},${shade[2]},${t * 0.5})`;
          oc.lineWidth = this.ballRadius * (0.4 + 0.6 * t);
          oc.stroke();
        }

        oc.beginPath();
        oc.arc(ball.pos.x, ball.pos.y, this.ballRadius, 0, Math.PI * 2);
        oc.fillStyle = `rgb(${shade[0]},${shade[1]},${shade[2]})`;
        oc.fill();
      }
    }
  }

  // ─── Bootstrap ──────────────────────────────────────────────

  const canvas = document.getElementById('vector-field-canvas') as HTMLCanvasElement | null;
  if (canvas) {
    new VectorFieldRenderer(canvas);
  }
</script>

