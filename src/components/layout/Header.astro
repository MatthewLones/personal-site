---
import ProfilePhoto from '../interactive/ProfilePhoto.astro';
---
<header class="header">
  <div class="header-top">
    <h1 class="greeting">Hey There!</h1>
  </div>

  <div class="header-body">
    <ProfilePhoto />

    <div class="contact-row">
      <div class="contact-info glass-box">
        <a href="/Matt_Lones_Resume.pdf" target="_blank" rel="noopener">Resume</a>
        <span class="divider">·</span>
        <a href="https://github.com/MatthewLones" target="_blank" rel="noopener">GitHub</a>
        <span class="divider">·</span>
        <a href="https://www.linkedin.com/in/matthew-lones/" target="_blank" rel="noopener">LinkedIn</a>
        <span class="divider">·</span>
        <button class="email-btn" id="copy-email" data-email="mattlones@queensu.ca">Email</button>
      </div>
      <span class="copied-toast" id="copied-toast">copied to clipboard</span>
    </div>
  </div>

  <p class="description">
    Second-year Applied Mathematics & Computer Engineering student at Queen's University.
    Interested in mathematics, AI engineering, and data work.
  </p>
</header>

<style>
  .header {
    margin-bottom: 4rem;
    position: relative;
    z-index: 1;
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .greeting {
    font-size: 2.5rem;
    font-weight: 700;
    user-select: none;
  }

  .header-body {
    margin-bottom: 1.25rem;
  }

  .contact-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: fit-content;
    padding: 0.6rem 1.25rem;
    font-size: 0.9rem;
  }

  .email-btn {
    position: relative;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    color: inherit;
    text-decoration: none;
  }

  .contact-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .copied-toast {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-style: italic;
    color: var(--color-text-secondary);
    opacity: 0;
    pointer-events: none;
    white-space: nowrap;
    transition: opacity 0.25s ease;
    position: relative;
    top: -2px;
  }

  .copied-toast.show {
    opacity: 0.5;
  }

  .divider {
    opacity: 0.4;
  }

  .description {
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 500px;
    color: var(--color-text-secondary);
  }
</style>

<script>
  const btn = document.getElementById('copy-email') as HTMLButtonElement | null;
  const toast = document.getElementById('copied-toast');
  if (btn && toast) {
    btn.addEventListener('click', async () => {
      const email = btn.dataset.email!;
      await navigator.clipboard.writeText(email);
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 1500);
    });
  }
</script>
