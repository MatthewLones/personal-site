---
import '../styles/global.css';

// Server-rendered — no prerender
const runtime = Astro.locals.runtime;
let isAuthed = false;

if (runtime?.env?.DB) {
  const cookie = Astro.request.headers.get('cookie') || '';
  const match = cookie.match(/admin_token=([^;]+)/);
  if (match) {
    const token = match[1];
    const row = await runtime.env.DB
      .prepare('SELECT token FROM admin_sessions WHERE token = ? AND expires_at > datetime(?)')
      .bind(token, new Date().toISOString())
      .first();
    isAuthed = !!row;
  }
}
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Admin — Matthew Lones</title>
</head>
<body class="admin-body">
  <div class="admin-container">
    <h1 class="admin-title">admin</h1>

    {!isAuthed ? (
      <div id="login-section">
        <form id="login-form" class="admin-form">
          <input type="password" id="admin-password" placeholder="password" class="admin-input" autocomplete="current-password" />
          <button type="submit" class="admin-btn">login</button>
        </form>
        <p id="login-error" class="admin-error"></p>
      </div>
    ) : (
      <div id="dashboard">
        <section class="admin-section">
          <h2>analytics</h2>
          <div id="analytics-data" class="admin-card">loading...</div>
        </section>

        <section class="admin-section">
          <h2>leaderboards</h2>
          <div class="admin-tabs">
            <button class="admin-tab active" data-game="lights_out">Lights Out</button>
            <button class="admin-tab" data-game="klondike">Klondike</button>
            <button class="admin-tab" data-game="peg_solitaire">Peg Solitaire</button>
            <button class="admin-tab" data-game="monotile_dash">Monotile Dash</button>
          </div>
          <div id="scores-list" class="admin-card">loading...</div>
          <div class="admin-seed-form">
            <h3>seed entry</h3>
            <form id="seed-form">
              <input type="text" id="seed-name" placeholder="name" class="admin-input" maxlength="20" />
              <input type="number" id="seed-time" placeholder="time (ms)" class="admin-input" />
              <input type="number" id="seed-moves" placeholder="moves" class="admin-input" />
              <input type="number" id="seed-tiles" placeholder="tiles (dash only)" class="admin-input" />
              <button type="submit" class="admin-btn">seed</button>
            </form>
          </div>
        </section>

        <section class="admin-section">
          <h2>wisdom</h2>
          <div id="wisdom-list" class="admin-card">loading...</div>
        </section>
      </div>
    )}
  </div>

  <script>
    // Login
    const loginForm = document.getElementById('login-form') as HTMLFormElement | null;
    loginForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const pw = (document.getElementById('admin-password') as HTMLInputElement).value;
      const res = await fetch('/api/admin/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pw }),
      });
      if (res.ok) {
        location.reload();
      } else {
        const errEl = document.getElementById('login-error');
        if (errEl) errEl.textContent = 'wrong password';
      }
    });

    // Dashboard
    let currentGame = 'lights_out';

    async function loadAnalytics() {
      const el = document.getElementById('analytics-data');
      if (!el) return;
      try {
        const res = await fetch('/api/admin/analytics');
        const data = await res.json();
        el.innerHTML = `
          <div class="stat-row"><span>total views</span><span>${data.totalViews}</span></div>
          <div class="stat-row"><span>today</span><span>${data.todayViews}</span></div>
          <div class="stat-row"><span>total scores</span><span>${data.totalScores}</span></div>
          <div class="stat-row"><span>unread wisdom</span><span>${data.unreadWisdom}</span></div>
          ${data.topReferrers?.length > 0 ? '<h4>top referrers</h4>' + data.topReferrers.map((r: { referrer: string; count: number }) => `<div class="stat-row"><span>${r.referrer}</span><span>${r.count}</span></div>`).join('') : ''}
        `;
      } catch { el.textContent = 'failed to load'; }
    }

    async function loadScores() {
      const el = document.getElementById('scores-list');
      if (!el) return;
      el.textContent = 'loading...';
      try {
        const res = await fetch(`/api/admin/scores?game=${currentGame}`);
        const scores = await res.json();
        if (scores.length === 0) {
          el.textContent = 'no scores';
          return;
        }
        el.innerHTML = scores.map((s: any) => `
          <div class="score-row ${s.flagged ? 'flagged' : ''}">
            <span>${s.player_name}</span>
            <span>${(s.time_ms / 1000).toFixed(1)}s${s.moves != null ? ' · ' + s.moves + 'm' : ''}${s.tiles_clicked != null ? ' · ' + s.tiles_clicked + ' tiles' : ''}${s.used_hint ? ' (hint)' : ''}</span>
            <span class="score-actions">
              <button onclick="toggleFlag(${s.id}, ${!s.flagged})">${s.flagged ? 'unflag' : 'flag'}</button>
              <button onclick="deleteScore(${s.id})">delete</button>
            </span>
          </div>
        `).join('');
      } catch { el.textContent = 'failed to load'; }
    }

    async function loadWisdom() {
      const el = document.getElementById('wisdom-list');
      if (!el) return;
      try {
        const res = await fetch('/api/admin/wisdom');
        const msgs = await res.json();
        if (msgs.length === 0) {
          el.textContent = 'no wisdom yet';
          return;
        }
        el.innerHTML = msgs.map((m: any) => `
          <div class="wisdom-row ${m.read ? 'read' : ''}">
            <span>"${m.message}"</span>
            <span>${new Date(m.created_at + 'Z').toLocaleDateString()}</span>
            ${!m.read ? `<button onclick="markRead(${m.id})">mark read</button>` : ''}
            <button onclick="deleteWisdom(${m.id})">delete</button>
          </div>
        `).join('');
      } catch { el.textContent = 'failed to load'; }
    }

    // Actions (global for onclick handlers)
    (window as any).toggleFlag = async (id: number, flagged: boolean) => {
      await fetch('/api/admin/scores', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'flag', id, flagged }),
      });
      loadScores();
    };

    (window as any).deleteScore = async (id: number) => {
      if (!confirm('Delete this score?')) return;
      await fetch('/api/admin/scores', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'delete', id }),
      });
      loadScores();
    };

    (window as any).markRead = async (id: number) => {
      await fetch('/api/admin/wisdom', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'mark_read', id }),
      });
      loadWisdom();
    };

    (window as any).deleteWisdom = async (id: number) => {
      await fetch('/api/admin/wisdom', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'delete', id }),
      });
      loadWisdom();
    };

    // Tab switching
    document.querySelectorAll<HTMLButtonElement>('.admin-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        currentGame = tab.dataset.game || 'lights_out';
        loadScores();
      });
    });

    // Seed form
    const seedForm = document.getElementById('seed-form') as HTMLFormElement | null;
    seedForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = (document.getElementById('seed-name') as HTMLInputElement).value;
      const timeMs = parseInt((document.getElementById('seed-time') as HTMLInputElement).value);
      const moves = parseInt((document.getElementById('seed-moves') as HTMLInputElement).value) || null;
      const tiles = parseInt((document.getElementById('seed-tiles') as HTMLInputElement).value) || null;
      if (!name || !timeMs) return;

      await fetch('/api/admin/scores', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'seed',
          game: currentGame,
          playerName: name,
          timeMs,
          moves,
          tilesClicked: tiles,
        }),
      });
      loadScores();
    });

    // Init dashboard
    if (document.getElementById('dashboard')) {
      loadAnalytics();
      loadScores();
      loadWisdom();
    }
  </script>

  <style>
    .admin-body {
      min-height: 100vh;
      display: flex;
      justify-content: center;
      padding: 2rem;
    }

    .admin-container {
      max-width: 700px;
      width: 100%;
    }

    .admin-title {
      font-family: var(--font-heading);
      font-size: 1.4rem;
      margin-bottom: 2rem;
      opacity: 0.7;
    }

    .admin-form {
      display: flex;
      gap: 0.5rem;
    }

    .admin-input {
      font-family: var(--controls-font);
      font-size: var(--controls-font-size);
      padding: 6px 12px;
      border: 1px solid var(--vf-arrow-color, #3a3020);
      border-radius: 4px;
      background: rgba(255, 255, 255, 0.08);
      color: var(--color-text-primary);
      outline: none;
    }

    .admin-btn {
      font-family: var(--controls-font);
      font-size: var(--controls-font-size);
      padding: 6px 16px;
      border: 1px solid var(--vf-arrow-color, #3a3020);
      border-radius: 4px;
      background: var(--vf-arrow-color, #3a3020);
      color: var(--color-bg-light, #BCC6AF);
      cursor: pointer;
    }

    .admin-error {
      color: #c44;
      font-size: 0.8rem;
      margin-top: 0.5rem;
    }

    .admin-section {
      margin-bottom: 2rem;
    }

    .admin-section h2 {
      font-family: var(--font-heading);
      font-size: 1.1rem;
      margin-bottom: 0.75rem;
      opacity: 0.7;
    }

    .admin-card {
      border: 1px solid rgba(58, 48, 32, 0.2);
      border-radius: 8px;
      padding: 0.75rem 1rem;
      font-family: var(--controls-font);
      font-size: var(--controls-font-size);
      color: var(--color-text-primary);
    }

    .admin-tabs {
      display: flex;
      gap: 0;
      margin-bottom: 0.5rem;
      border: 1px solid var(--vf-arrow-color, #3a3020);
      border-radius: 4px;
      overflow: hidden;
      width: fit-content;
    }

    .admin-tab {
      font-family: var(--controls-font);
      font-size: var(--controls-font-size);
      padding: 4px 12px;
      border: none;
      border-right: 1px solid var(--vf-arrow-color, #3a3020);
      background: transparent;
      color: var(--vf-arrow-color, #3a3020);
      cursor: pointer;
    }

    .admin-tab:last-child { border-right: none; }
    .admin-tab.active {
      background: var(--vf-arrow-color, #3a3020);
      color: var(--color-bg-light, #BCC6AF);
    }

    .stat-row, .score-row, .wisdom-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 4px 0;
      gap: 1rem;
      border-bottom: 1px solid rgba(58, 48, 32, 0.08);
    }

    .stat-row:last-child, .score-row:last-child, .wisdom-row:last-child {
      border-bottom: none;
    }

    .score-row.flagged { opacity: 0.4; text-decoration: line-through; }
    .wisdom-row.read { opacity: 0.5; }

    .score-actions button, .wisdom-row button {
      font-family: var(--controls-font);
      font-size: 0.65rem;
      padding: 2px 8px;
      border: 1px solid rgba(58, 48, 32, 0.3);
      border-radius: 3px;
      background: transparent;
      color: var(--color-text-primary);
      cursor: pointer;
      opacity: 0.6;
    }

    .score-actions button:hover, .wisdom-row button:hover { opacity: 1; }

    .admin-seed-form {
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px solid rgba(58, 48, 32, 0.1);
    }

    .admin-seed-form h3 {
      font-family: var(--font-heading);
      font-size: 0.9rem;
      margin-bottom: 0.5rem;
      opacity: 0.5;
    }

    .admin-seed-form form {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .admin-seed-form .admin-input { width: 100px; }
  </style>
</body>
</html>
