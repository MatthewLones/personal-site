---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import HatTiling from '../components/interactive/HatTiling.astro';
import VectorField from '../components/interactive/VectorField.astro';
import GaltonBoard from '../components/interactive/GaltonBoard.astro';
import DoublePendulum from '../components/interactive/DoublePendulum.astro';
import PhotoScatter from '../components/interactive/PhotoScatter.astro';
import LightsOut from '../components/interactive/LightsOut.astro';
import BackFromTheKlondike from '../components/interactive/BackFromTheKlondike.astro';
import PegSolitaire from '../components/interactive/PegSolitaire.astro';
---
<BaseLayout title="Matthew Lones">
  <HatTiling slot="tiling-bg" />
  <VectorField slot="margin-right" />
  <PhotoScatter slot="margin-right" />
  <GaltonBoard slot="galton" />
  <DoublePendulum slot="pendulum" />

  <Header />

  <section class="placeholder-section">
    <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>
    <p>Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.</p>
    <p>Curabitur pretium tincidunt lacus. Nulla gravida orci a odio. Nullam varius, turpis et commodo pharetra, est eros bibendum elit, nec luctus magna felis sollicitudin mauris. Integer in mauris eu nibh euismod gravida.</p>
  </section>

  <section class="puzzle-drawer">
    <h2 class="puzzle-drawer-title">Some puzzles I think are cool <span class="puzzle-drawer-hint">(click the titles to learn more)</span></h2>
    <div class="puzzle-drawer-row">
      <div class="puzzle-slot">
        <LightsOut />
      </div>
      <div class="puzzle-slot">
        <BackFromTheKlondike />
      </div>
      <div class="puzzle-slot">
        <PegSolitaire />
      </div>
    </div>
  </section>

  <section class="wisdom-section">
    <h3 class="wisdom-title">drop some wisdom</h3>
    <form class="wisdom-form" id="wisdom-form" autocomplete="off">
      <input type="text" class="wisdom-input" id="wisdom-input" placeholder="say something nice (or weird)" maxlength="500" />
      <button type="submit" class="wisdom-btn">drop</button>
    </form>
    <span class="wisdom-feedback" id="wisdom-feedback"></span>
  </section>
</BaseLayout>

<script>
  // Wisdom form
  const wisdomForm = document.getElementById('wisdom-form') as HTMLFormElement | null;
  wisdomForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = document.getElementById('wisdom-input') as HTMLInputElement;
    const feedback = document.getElementById('wisdom-feedback');
    const message = input.value.trim();
    if (!message) return;

    const btn = wisdomForm.querySelector('button') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '...';

    try {
      const res = await fetch('/api/wisdom', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message }),
      });
      if (res.ok) {
        input.value = '';
        if (feedback) {
          feedback.textContent = 'dropped';
          setTimeout(() => { feedback.textContent = ''; }, 2000);
        }
      } else {
        const data = await res.json();
        if (feedback) feedback.textContent = data.error || 'failed';
      }
    } catch {
      if (feedback) feedback.textContent = 'failed';
    }

    btn.disabled = false;
    btn.textContent = 'drop';
  });

  // Page view tracking
  fetch('/api/track', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ path: location.pathname, referrer: document.referrer }),
  }).catch(() => {});
</script>

<style>
  .placeholder-section {
    margin-top: 2rem;
    max-width: 500px;
  }

  .placeholder-section p {
    line-height: 1.7;
    margin-bottom: 1.5rem;
    color: var(--color-text-secondary);
    opacity: 0.5;
    font-style: italic;
  }

  /* ─── Puzzle Drawer ───────────────────────────── */

  .puzzle-drawer {
    margin-top: 6rem;
  }

  .puzzle-drawer-title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 2rem;
  }

  .puzzle-drawer-hint {
    opacity: 0.45;
  }

  .puzzle-drawer-row {
    /* Break out of content column to span full viewport.
       Content card starts at --margin-left + 2rem padding from viewport left. */
    width: 100vw;
    margin-left: calc(-1 * var(--margin-left) - 2rem);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
  }

  .puzzle-slot {
    flex: none;
  }

  @media (max-width: 600px) {
    .puzzle-drawer-row {
      width: auto;
      margin-left: 0;
      flex-direction: column;
      gap: 2rem;
    }
  }

  /* ─── Wisdom Section ────────────────────────────── */

  .wisdom-section {
    margin-top: 8rem;
    max-width: 400px;
  }

  .wisdom-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.75rem 0;
    opacity: 0.6;
  }

  .wisdom-form {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .wisdom-input {
    flex: 1;
    font-family: var(--controls-font);
    font-size: var(--controls-font-size);
    padding: 6px 0;
    border: none;
    border-bottom: 1px solid var(--vf-arrow-color, #3a3020);
    background: transparent;
    color: var(--color-text-primary);
    outline: none;
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  .wisdom-input:focus {
    opacity: 0.9;
  }

  .wisdom-input::placeholder {
    color: var(--color-text-primary);
    opacity: 0.3;
  }

  .wisdom-btn {
    font-family: var(--controls-font);
    font-size: var(--controls-font-size);
    padding: 4px 12px;
    border: 1px solid var(--vf-arrow-color, #3a3020);
    border-radius: 4px;
    background: transparent;
    color: var(--vf-arrow-color, #3a3020);
    cursor: pointer;
    opacity: 0.45;
    transition: opacity 0.2s, background 0.15s, color 0.15s;
    line-height: 1;
  }

  .wisdom-btn:hover {
    opacity: 0.85;
    background: var(--vf-arrow-color, #3a3020);
    color: var(--color-bg-light, #BCC6AF);
  }

  .wisdom-feedback {
    font-family: var(--controls-font);
    font-size: var(--controls-font-size);
    color: var(--color-text-primary);
    opacity: 0.5;
    margin-left: 0.5rem;
  }
</style>
