---
import GrainOverlay from '../components/layout/GrainOverlay.astro';
import LoadingScreen from '../components/interactive/LoadingScreen.astro';
import '../styles/global.css';
import '../styles/layout.css';

interface Props {
  title?: string;
}

const { title = 'Matthew Lones' } = Astro.props;
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Matthew Lones — Applied Mathematics & Computer Engineering, Queen's University" />
  <link rel="canonical" href="https://www.mattlones.com/" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://www.mattlones.com/" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content="Matthew Lones — Applied Mathematics & Computer Engineering, Queen's University" />
  <meta property="og:image" content="https://www.mattlones.com/photos/profile-formal.jpg" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content="Matthew Lones — Applied Mathematics & Computer Engineering, Queen's University" />
  <meta name="twitter:image" content="https://www.mattlones.com/photos/profile-formal.jpg" />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Matthew Lones",
    "alternateName": "Matt Lones",
    "url": "https://www.mattlones.com",
    "image": "https://www.mattlones.com/photos/profile-formal.jpg",
    "jobTitle": "Applied Mathematics & Computer Engineering Student",
    "affiliation": {
      "@type": "CollegeOrUniversity",
      "name": "Queen's University"
    },
    "sameAs": [
      "https://github.com/MatthewLones",
      "https://www.linkedin.com/in/matthew-lones/"
    ]
  })} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preload" href="/fonts/PlayfairDisplay-Regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/PlayfairDisplay-Italic.woff2" as="font" type="font/woff2" crossorigin />
  <title>{title}</title>
</head>
<body>
  <!-- Loading screen overlay (first for instant coverage) -->
  <LoadingScreen />

  <!-- Full-page monotile tiling background -->
  <slot name="tiling-bg" />

  <!-- Layer 1: Grain overlay -->
  <GrainOverlay />

  <!-- Layer 2: Content grid on top -->
  <div class="page-grid">
    <slot name="galton" />
    <slot name="pendulum" />
    <aside class="margin-left">
      <slot name="margin-left" />
    </aside>
    <main class="content-card">
      <slot />
    </main>
    <aside class="margin-right">
      <slot name="margin-right" />
    </aside>
  </div>
</body>
</html>
